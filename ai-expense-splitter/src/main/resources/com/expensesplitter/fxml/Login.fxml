<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<!--
    Login Screen - AI-Powered Expense Splitter
    Controller: com.expensesplitter.controllers.LoginController
    Student   : Muhammad Arham | L1F23BSSE0372
-->
<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.expensesplitter.controllers.LoginController"
           prefWidth="900.0" prefHeight="600.0"
           style="-fx-background-color: #F5F7FA;">

    <stylesheets>
        <URL value="@../css/styles.css" />
    </stylesheets>

    <VBox alignment="CENTER" spacing="10">
        <!-- Main Card container -->
        <VBox alignment="CENTER" spacing="20" styleClass="card" maxWidth="400.0" prefWidth="400.0">
            <!-- Header -->
            <VBox alignment="CENTER" spacing="5">
                <Label text="AI Expense Splitter" styleClass="heading" />
                <Label text="Sign in to your account" style="-fx-text-fill: #7F8C8D; -fx-font-size: 14px;" />
            </VBox>

            <!-- Form Fields -->
            <VBox alignment="CENTER_LEFT" spacing="15">
                <VBox spacing="5">
                    <Label text="Email Address" style="-fx-font-weight: bold; -fx-text-fill: #34495E;" />
                    <TextField fx:id="emailField" promptText="Enter your email" styleClass="text-field" maxWidth="Infinity" />
                </VBox>

                <VBox spacing="5">
                    <Label text="Password" style="-fx-font-weight: bold; -fx-text-fill: #34495E;" />
                    <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="password-field" maxWidth="Infinity" onAction="#handleLogin" />
                </VBox>
            </VBox>

            <!-- Error Label -->
            <Label fx:id="errorLabel" styleClass="error-label" wrapText="true" alignment="CENTER" textAlignment="CENTER" />

            <!-- Actions -->
            <VBox alignment="CENTER" spacing="15" maxWidth="Infinity">
                <Button text="Login" onAction="#handleLogin" styleClass="btn-primary" maxWidth="Infinity" />
                
                <HBox alignment="CENTER" spacing="5">
                    <Label text="Don't have an account?" style="-fx-text-fill: #7F8C8D;" />
                    <Hyperlink text="Register" onAction="#handleGoToRegister" style="-fx-text-fill: #4A6FA5; -fx-font-weight: bold; -fx-underline: false;" />
                </HBox>
            </VBox>
        </VBox>
    </VBox>
</StackPane>
